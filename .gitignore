venv/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
dist/
build/
.DS_Store
# Raw wiki/API fetches — large intermediates, re-fetchable from each dataset's _provenance.source_urls.
# Ignore the raw DATA, but KEEP the extraction/builder scripts that live alongside it (reproducibility).
data/raw/**
!data/raw/**/
!data/raw/**/*.py
# Drop-rate brick: the dropsline raw cache IS committed provenance (drop_rates.json
# regenerates from it byte-stably, no live fetch at validate time — like kg/*.json).
!data/raw/dropsline_*.json
# Quest reward source-grounding cache IS committed provenance (offline verifier)
!data/raw/quest_reward_blocks.json
# Diary reward source-grounding cache IS committed provenance (offline verifier;
# rebuilt from achievement_diaries.json's committed wiki reward prose)
!data/raw/diary_reward_blocks.json
# Storeline bucket IS committed provenance (offline verifier; source-grounded shop stock)
!data/raw/storeline_bucket.json
# Wiki location categories IS committed provenance (offline snapshot for world skeleton shape test)
!data/raw/wiki_location_categories.json
# Wiki location infoboxes IS committed provenance (infobox-location parenting brick for world rehoming)
!data/raw/wiki_location_infoboxes.json
# Wiki shop categories IS committed provenance (offline snapshot for all-shops layer type-category membership)
!data/raw/wiki_shop_categories.json
# Wiki shop infoboxes IS committed provenance (offline snapshot for all-shops layer location/members/owner)
!data/raw/wiki_shop_infoboxes.json
.superpowers/
