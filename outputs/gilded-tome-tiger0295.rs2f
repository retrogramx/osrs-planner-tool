/*@ define:module:fallback
name: Value fallback (SS→E)
*/
rule (IRONMAN && value:<HIDE_FLOOR) { hidden = true; }
rule (IRONMAN && value:>=10000000) { backgroundColor = "#ffff2b2b"; borderColor = "#ffffffff"; textColor = "#fff5f5f5"; fontType = 3; textAccent = 3; icon = CurrentItem(); sound = 3925; showLootbeam = true; lootbeamColor = "#ffff2b2b"; }
rule (IRONMAN && value:>=1000000) { backgroundColor = "#ffff45d6"; borderColor = "#ff181818"; textColor = "#ff141414"; fontType = 3; textAccent = 3; icon = CurrentItem(); sound = 3925; showLootbeam = true; lootbeamColor = "#ffff45d6"; }
rule (IRONMAN && value:>=100000) { backgroundColor = "#ffff9a1f"; borderColor = "#ff181818"; textColor = "#ff141414"; fontType = 2; textAccent = 3; icon = CurrentItem(); sound = 3925; }
rule (IRONMAN && value:>=10000) { backgroundColor = "#ff27c2ff"; borderColor = "#ff181818"; textColor = "#ff141414"; fontType = 1; textAccent = 3; icon = CurrentItem(); }
rule (IRONMAN && value:>=1000) { backgroundColor = "#ff52e052"; borderColor = "#ff181818"; textColor = "#ff141414"; fontType = 1; textAccent = 3; icon = CurrentItem(); }
rule (IRONMAN && value:>=100) { textColor = "#ff6f7780"; textAccent = 1; fontType = 1; }
rule (IRONMAN && value:>=0) { textColor = "#9e8c8c8c"; textAccent = 1; fontType = 1; menuSort = -10000; }

