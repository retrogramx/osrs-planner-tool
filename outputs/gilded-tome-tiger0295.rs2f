/*@ define:module:coins
name: Coins (gold, darkening by stack)
*/
rule (IRONMAN && id:[995, 13204] && value:>=100000000) { backgroundColor = "#ff4a3604"; borderColor = "#ffffffff"; textColor = "#fff5f5f5"; fontType = 1; textAccent = 3; icon = CurrentItem(); }
rule (IRONMAN && id:[995, 13204] && value:>=10000000) { backgroundColor = "#ff63490a"; borderColor = "#ffffffff"; textColor = "#fff5f5f5"; fontType = 1; textAccent = 3; icon = CurrentItem(); }
rule (IRONMAN && id:[995, 13204] && value:>=1000000) { backgroundColor = "#ff7c5d10"; borderColor = "#ffffffff"; textColor = "#fff5f5f5"; fontType = 1; textAccent = 3; icon = CurrentItem(); }
