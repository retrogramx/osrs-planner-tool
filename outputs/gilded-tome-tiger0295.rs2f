meta {
    name = "Tiger0295";
    description = "Tiger0295 collection-log filter: beams your 1429 missing slots (purple), tiered by rarity. Clog state is public via TempleOSRS; no bank data included.";
}

#define IRONMAN accountType:1
/*@ define:input:settings
label: Hide below value
type: number
group: Hide
*/
#define HIDE_FLOOR 0

/*@ define:module:settings
name: Settings
*/
/*@ define:input:settings
label: Show world spawns
type: boolean
group: Show
*/
#define SHOW_WORLD_SPAWNS true
apply (IRONMAN && !SHOW_WORLD_SPAWNS && ownership:0) { hidden = true; }
/*@ define:input:settings
label: Show unowned drops
type: boolean
group: Show
*/
#define SHOW_UNOWNED true
apply (IRONMAN && !SHOW_UNOWNED && ownership:2) { hidden = true; }
/*@ define:input:settings
label: Despawn timer
type: boolean
group: Show
*/
#define SHOW_DESPAWN true
apply (IRONMAN && SHOW_DESPAWN) { showDespawn = true; }
/*@ define:input:settings
label: Item value
type: boolean
group: Show
*/
#define SHOW_VALUE true
apply (IRONMAN && SHOW_VALUE) { showValue = true; }

/*@ define:module:tailoring
name: Account tailoring
*/
/*@ define:input:tailoring
label: Hide items already in my bank
type: boolean
group: Tailor
*/
#define HIDE_OWNED false
