rule (IRONMAN && id:[995, 13204] && value:>=10000) { backgroundColor = "#ffb0881c"; borderColor = "#ff181818"; textColor = "#ff141414"; fontType = 1; textAccent = 3; icon = CurrentItem(); }
rule (IRONMAN && id:[995, 13204] && value:>=1000) { backgroundColor = "#ffc99e22"; borderColor = "#ff181818"; textColor = "#ff141414"; fontType = 1; textAccent = 3; icon = CurrentItem(); }
rule (IRONMAN && id:[995, 13204] && value:>=100) { backgroundColor = "#ffddb22c"; borderColor = "#ff181818"; textColor = "#ff141414"; fontType = 1; textAccent = 3; icon = CurrentItem(); }
